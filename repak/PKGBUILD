# Maintainer: Imperator Storm <imperatorstorm@protonmail.com>

pkgname=repak
pkgver=0.2.3
pkgrel=5
pkgdesc='Unreal Engine .pak file library and CLI in rust'
url='https://github.com/trumank/repak'
license=('Apache-2.0' 'MIT')
makedepends=(cargo git)
depends=(glibc libgcc zstd)
options=(!lto)
# unsure if repak actually supports 32bit architectures
arch=(i686 x86_64 armv6h armv7h aarch64)
source=(git+https://github.com/trumank/repak#tag=v$pkgver)
sha256sums=('2ec9119bdc58cbdede7f2ebfcc1d0a8324c587918bbe3fdf880d5af252fd26cb')

# Use debug
export CARGO_PROFILE_RELEASE_DEBUG=2 CARGO_PROFILE_RELEASE_STRIP=false

# Use LTO
export CARGO_PROFILE_RELEASE_LTO=true CARGO_PROFILE_RELEASE_CODEGEN_UNITS=1
# Unbundle
export ZSTD_SYS_USE_PKG_CONFIG=1

prepare() {
    cd $srcdir/repak
    cargo fetch --locked --target host-tuple
}

build() {
	cd $srcdir/repak
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --profile dist --all-features
}

check() {
	cd $srcdir/repak
	export RUSTUP_TOOLCHAIN=stable
    cargo test --frozen --all-features
}

package() {
	cd $srcdir/repak
    install -Dm0755 -t "$pkgdir/usr/bin/" "target/dist/repak"
}
